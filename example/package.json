{
  "name": "vite-plugin-dtsbom-example",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "sbom:list": "node -e \"const fs=require('fs');const p='dist';for(const f of['sbom.cyclonedx.json','sbom.spdx.json']){const j=JSON.parse(fs.readFileSync(p+'/'+f,'utf8'));const n=f.includes('cyclonedx')?(j.components||[]).length:(j.packages||[]).length-1;console.log(f+': root +',n,'deps');}\"",
    "postinstall": "node -e \"const fs=require('fs');const p=require('path');const t=p.join('node_modules','vite-plugin-dtsbom','node_modules','vite');if(fs.existsSync(t))fs.rmSync(t,{recursive:true,force:true});\""
  },
  "overrides": {
    "vite-plugin-dtsbom": {
      "vite": "$vite"
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vite-plugin-dtsbom": "file:.."
  }
}
